# ==============================================================================
# .gitignore — Cloud Security Review Board (CSRB) Agent
# ==============================================================================

# ----- Python byte-compiled files -----
__pycache__/
*.py[cod]
*$py.class

# ----- Virtual environments -----
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# ----- Secrets & API keys (NEVER commit these) -----
.env
.env.local
.env.*.local

# ----- Runtime-generated data (auto-created on first run) -----
data/csrb.db
data/memory.json

# ----- uv package manager -----
# Uncomment the line below if you prefer not to commit the lock file:
# uv.lock

# ----- Testing & coverage -----
.pytest_cache/
htmlcov/
.coverage
*.cover

# ----- IDE & editor configs -----
.vscode/
.idea/
*.swp
*.swo

# ----- OS noise -----
.DS_Store
Thumbs.db
desktop.ini
