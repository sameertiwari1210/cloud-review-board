# ==============================================================================
# Cloud Security Review Board (CSRB) Agent — Local Configuration Template
# ==============================================================================
# Copy this file to a new file named '.env' in this same directory and configure
# it according to your provider of choice.

# ------------------------------------------------------------------------------
# 1. Standard OpenAI API Configuration
# ------------------------------------------------------------------------------
# Use this section if you are connecting to the official OpenAI API cloud.
#
# OPENAI_API_KEY=sk-proj-yourActualOpenAiKeyHere
# OPENAI_MODEL=gpt-4o-mini  # (Recommended) Or gpt-4o

# ------------------------------------------------------------------------------
# 2. Local LM Studio Configuration
# ------------------------------------------------------------------------------
# Use this section if you are running models locally on LM Studio.
# Make sure LM Studio's Local Server is running on port 1234.
#
# OPENAI_API_BASE=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio  # LM Studio does not require a real key, but client expects some value
# OPENAI_MODEL=model-identifier-loaded-in-lm-studio

# ------------------------------------------------------------------------------
# 3. Local Ollama Configuration
# ------------------------------------------------------------------------------
# Use this section if you are running models locally on Ollama.
# Make sure Ollama's service is running.
# Note: Ollama's OpenAI compatibility endpoint is on /v1.
#
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=ollama  # Ollama does not require a real key, but client expects some value
# OPENAI_MODEL=llama3  # (Or mistral, phi3, codegemma, etc.)

# ------------------------------------------------------------------------------
# Active Configuration (Default is standard OpenAI template)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=
